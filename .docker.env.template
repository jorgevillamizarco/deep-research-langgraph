# Deep Research Agent — Docker environment variables
# Copy this to .docker.env and fill in your API keys
#
# Model selection:
#   WORKER_MODEL — used for research, planning, composition (bulk work)
#   CRITIC_MODEL — used for quality evaluation (MUST be stronger than worker!)
#   Default: worker=deepseek-v4-flash, critic=deepseek-v4-pro
#   Best: worker=deepseek-v4-flash, critic=claude-sonnet-4 or gpt-4o
#   WARNING: If CRITIC_MODEL == WORKER_MODEL, the evaluator logs a warning.
#   Same-model evaluation produces inflated scores (LLMs grading own output).

WORKER_API_KEY=
WORKER_API_BASE=https://api.deepseek.com
WORKER_MODEL=deepseek-v4-flash
CRITIC_API_KEY=
CRITIC_API_BASE=https://api.deepseek.com
CRITIC_MODEL=deepseek-v4-pro
MAX_SEARCH_ITERATIONS=3
SEARXNG_URL=http://searxng:8080
RESEARCH_OUTPUT_DIR=/data
CHECKPOINT_DB_PATH=/app/checkpoints/checkpoints.db
