# Deep Research Agent — Docker environment variables
# Copy this to .docker.env and fill in your API keys
#
# Model selection:
#   WORKER_MODEL — used for research, planning, composition (bulk work)
#   CRITIC_MODEL — used for quality evaluation (use a stronger model here!)
#   For best results: WORKER_MODEL=deepseek-v4-flash, CRITIC_MODEL=claude-sonnet-4
#   Both default to deepseek-v4-flash (fast, cost-effective)

WORKER_API_KEY=
WORKER_API_BASE=https://api.deepseek.com
WORKER_MODEL=deepseek-v4-flash
CRITIC_API_KEY=
CRITIC_API_BASE=https://api.deepseek.com
CRITIC_MODEL=deepseek-v4-flash
MAX_SEARCH_ITERATIONS=3
SEARXNG_URL=http://searxng:8080
RESEARCH_OUTPUT_DIR=/data
